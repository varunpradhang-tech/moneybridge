rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function userSafeCreateKeys() {
      return request.resource.data.keys().hasOnly([
        "phone",
        "mobileVerified",
        "borrowerPurpose",
        "referralCode",
        "referredByCode",
        "freeLeadsUsed",
        "freeLeadWindowStartedAt",
        "kycStatus",
        "kycRequestedAt",
        "createdAt",
        "updatedAt"
      ]);
    }

    function userSafeUpdateKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "phone",
        "mobileVerified",
        "borrowerPurpose",
        "referralCode",
        "referredByCode",
        "freeLeadsUsed",
        "freeLeadWindowStartedAt",
        "kycStatus",
        "kycRequestedAt",
        "updatedAt"
      ]);
    }

    function validUserWrite(userId) {
      return owns(userId)
        && request.resource.data.phone is string
        && request.resource.data.mobileVerified is bool
        && (!("referralCode" in request.resource.data) || request.resource.data.referralCode.matches("^MB-[A-Z0-9-]{4,24}$"))
        && (!("referredByCode" in request.resource.data) || request.resource.data.referredByCode.matches("^MB-[A-Z0-9-]{4,24}$"))
        && (!("freeLeadsUsed" in request.resource.data) || (request.resource.data.freeLeadsUsed is int && request.resource.data.freeLeadsUsed >= 0 && request.resource.data.freeLeadsUsed <= 3))
        && (!("freeLeadWindowStartedAt" in request.resource.data) || (request.resource.data.freeLeadWindowStartedAt is int && request.resource.data.freeLeadWindowStartedAt > 0));
    }

    function validListingOwner() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function validListingFields() {
      return request.resource.data.keys().hasOnly([
        "userId",
        "name",
        "type",
        "city",
        "distance",
        "amount",
        "interest",
        "duration",
        "verified",
        "mobileVerified",
        "aadharVerified",
        "premium",
        "purpose",
        "initials",
        "phone",
        "terms",
        "createdAt",
        "updatedAt"
      ])
      && request.resource.data.name is string
      && request.resource.data.type in ["provider", "receiver"]
      && request.resource.data.city is string
      && request.resource.data.amount is int
      && request.resource.data.amount > 0
      && request.resource.data.interest is number
      && request.resource.data.interest >= 0
      && request.resource.data.purpose is string
      && request.resource.data.terms is string
      && request.resource.data.phone == userData().phone
      && request.resource.data.mobileVerified == userData().get("mobileVerified", false)
      && request.resource.data.verified == userData().get("verifiedProfile", false)
      && request.resource.data.premium == userData().get("premium", false)
      && request.resource.data.aadharVerified == false;
    }

    function validKycCreate() {
      return signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "userId",
          "phone",
          "fullName",
          "city",
          "idType",
          "filePath",
          "fileUrl",
          "status",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.status == "pending"
        && request.resource.data.filePath.matches("^kyc/" + request.auth.uid + "/.*")
        && request.resource.data.phone is string
        && request.resource.data.fullName is string
        && request.resource.data.city is string
        && request.resource.data.idType in ["Aadhaar", "PAN", "Passport", "Driving licence", "Voter ID"];
    }

    match /users/{userId} {
      allow read: if owns(userId);
      allow create: if validUserWrite(userId) && userSafeCreateKeys();
      allow update: if validUserWrite(userId) && userSafeUpdateKeys();
      allow delete: if false;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if validListingOwner() && validListingFields();
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && validListingOwner()
        && validListingFields();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /payments/{paymentId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /kycRequests/{requestId} {
      allow create: if validKycCreate();
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "reporterId",
          "reportedUserId",
          "listingId",
          "reason",
          "details",
          "status",
          "createdAt"
        ])
        && request.resource.data.status == "open";
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
